---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import LinksBar from "../components/LinksBar.astro";
import PhotoGrid from "../components/PhotoGrid.astro";
import ResumeDownload from "../components/ResumeDownload.astro";
import { Content as About } from "../content/about.md";
import { Content as Resume } from "../content/resume.md";
---

<Base title="jakeblackstone" description="Personal site of Jake Blackstone.">
  <div class="intro">
    <img
      class="headshot"
      src="/images/headshot.jpg"
      width="240"
      height="240"
      alt="Portrait of Jake Blackstone"
    />
    <div class="intro-text">
      <h1>Jake Blackstone</h1>
      <p class="tagline">Back-end engineer. Queens, NY.</p>
    </div>
  </div>

  <LinksBar />

  <Section title="About" open={true}>
    <About />
  </Section>

  <Section title="Resume" open={false}>
    <Resume />
    <div class="resume-actions">
      <ResumeDownload />
    </div>
  </Section>

  <PhotoGrid />
</Base>

<style>
  .intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-bottom: var(--space-5);
  }

  .headshot {
    width: 160px;
    height: auto;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border);
  }

  .intro-text h1 {
    margin: 0;
    font-size: 1.75rem;
    line-height: 1.2;
  }

  .tagline {
    margin: var(--space-1) 0 0;
    color: var(--fg-muted);
  }

  .resume-actions {
    padding-top: var(--space-4);
  }

  @media (min-width: 640px) {
    .intro {
      flex-direction: row;
      align-items: center;
      gap: var(--space-5);
    }

    .headshot {
      width: 200px;
    }

    .intro-text h1 {
      font-size: 2rem;
    }
  }
</style>

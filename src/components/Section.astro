---
interface Props {
  title: string;
  open?: boolean;
}

const { title, open = true } = Astro.props;
---

<details class="section" open={open}>
  <summary>
    <svg
      class="caret"
      aria-hidden="true"
      focusable="false"
      width="12"
      height="12"
      viewBox="0 0 12 12"
    >
      <path
        d="M3 2l5 4-5 4"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
    <span class="title">{title}</span>
  </summary>
  <div class="body">
    <slot />
  </div>
</details>

<style>
  .section {
    border-top: 1px solid var(--border);
    padding-block: var(--space-5);
  }

  .section:first-of-type {
    border-top: 0;
    padding-top: 0;
  }

  summary {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    list-style: none;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--fg);
    padding-block: var(--space-2);
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: var(--radius);
  }

  .caret {
    color: var(--fg-muted);
    transition: transform 150ms ease;
    flex: none;
  }

  .section[open] > summary .caret {
    transform: rotate(90deg);
  }

  .title {
    line-height: 1.2;
  }

  .body {
    padding-top: var(--space-3);
    color: var(--fg);
  }

  .body :global(p) {
    margin-bottom: var(--space-4);
  }

  .body :global(p:last-of-type) {
    margin-bottom: 0;
  }

  .body :global(h2) {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-top: var(--space-5);
    margin-bottom: var(--space-3);
  }

  .body :global(h2:first-child) {
    margin-top: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .caret {
      transition: none;
    }
  }
</style>
